DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-reasoner
AI_TIMEOUT_SECONDS=60

DATABASE_URL=sqlite:///psysight.db
SECRET_KEY=replace_with_a_secure_random_secret

FRONTEND_ORIGIN=http://localhost:8003
ADMIN_EXPORT_TOKEN=replace_with_admin_token
INTERNAL_API_TOKEN=psysight-internal-dev-token

VISION_MODEL_DIR=assets/models-cache
VISION_MODEL_DOWNLOAD_TIMEOUT_SECONDS=180
VISION_AUTO_DOWNLOAD_ENABLED=true
VISION_RELEASE_BASE_URL=https://github.com/YouXiangyu/PsySight/releases/download/models-v1
VISION_FACE_MODEL_URL=
VISION_EXPR_MODEL_URL=
VISION_FACE_MODEL_SHA256=
VISION_EXPR_MODEL_SHA256=
VISION_MAX_IMAGE_BYTES=1048576
